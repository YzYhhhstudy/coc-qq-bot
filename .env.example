# QQ 开放平台（q.qq.com → 我的机器人 → 开发设置）
QQ_APP_ID=你的AppID
QQ_APP_SECRET=你的AppSecret

# Supercell 开发者（developer.clashofclans.com）
COC_TOKEN=你的CoC_API_Token
# 直连用官方地址；服务器 IP 不固定时改用 RoyaleAPI 代理 https://cocproxy.royaleapi.dev/v1
COC_BASE_URL=https://api.clashofclans.com/v1

# 绑定关系数据库文件
DB_PATH=bindings.db

# 自动更新（默认开）：机器人每天对比一次 GitHub main，有新版本自动 git pull+重启
# 关掉改成 AUTO_UPDATE=0，届时「版本」指令会提示手动跑 update.bat
AUTO_UPDATE=1
# fork 了仓库的话改成你自己的 owner/repo
GITHUB_REPO=YzYhhhstudy/coc-qq-bot
